<Window x:Class="ECFtoCSV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource str_window_title}"
        Width="720" Height="610" MinWidth="560" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin"     Value="0,0,0,10"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding"                  Value="5,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height"                   Value="28"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Height"  Value="28"/>
            <Setter Property="Cursor"  Value="Hand"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight"        Value="Normal"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding"           Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight"        Value="Normal"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Kopfzeile mit Sprachwahl ══ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource str_app_title}" FontSize="22" FontWeight="Bold" Foreground="#1a5c96"/>
                <TextBlock Text="{DynamicResource str_app_subtitle}" TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
            <ComboBox Grid.Column="1" x:Name="CmbLanguage" Width="125"
                      VerticalAlignment="Center" Margin="15,0,0,0"
                      SelectionChanged="CmbLanguage_SelectionChanged">
                <ComboBoxItem Tag="de" Content="🇩🇪  Deutsch"/>
                <ComboBoxItem Tag="en" Content="🇬🇧  English"/>
                <ComboBoxItem Tag="fr" Content="🇫🇷  Français"/>
            </ComboBox>
        </Grid>

        <!-- ══ ECF-Sektion ══ -->
        <GroupBox Grid.Row="1" Header="{DynamicResource str_ecf_group}">
            <StackPanel>
                <DockPanel Margin="0,4,0,6">
                    <Label DockPanel.Dock="Left" Content="{DynamicResource str_label_input}" Width="68"/>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource str_btn_browse}" Margin="6,0,0,0"
                            Click="BrowseEcfInput_Click"
                            ToolTip="{DynamicResource str_tt_ecf_browse}"/>
                    <TextBox x:Name="TxtEcfInput" ToolTip="{DynamicResource str_tt_ecf_input}"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="68,0,0,5">
                    <RadioButton x:Name="RbEcfOverwrite" GroupName="EcfOut"
                                 Content="{DynamicResource str_rb_overwrite}"
                                 IsChecked="True" Margin="0,0,24,0"
                                 Checked="EcfOutOption_Changed"
                                 ToolTip="{DynamicResource str_tt_rb_overwrite_ecf}"/>
                    <RadioButton x:Name="RbEcfSeparate" GroupName="EcfOut"
                                 Content="{DynamicResource str_rb_separate}"
                                 Checked="EcfOutOption_Changed"
                                 ToolTip="{DynamicResource str_tt_rb_separate_ecf}"/>
                </StackPanel>
                <DockPanel Margin="68,0,0,4">
                    <Button DockPanel.Dock="Right" x:Name="BtnBrowseEcfOutput"
                            Content="{DynamicResource str_btn_browse}" Margin="6,0,0,0" IsEnabled="False"
                            Click="BrowseEcfOutput_Click"
                            ToolTip="{DynamicResource str_tt_ecf_output_browse}"/>
                    <TextBox x:Name="TxtEcfOutput" IsEnabled="False" Foreground="Gray"
                             ToolTip="{DynamicResource str_tt_ecf_output}"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- ══ CSV-Sektion ══ -->
        <GroupBox Grid.Row="2" Header="{DynamicResource str_csv_group}">
            <StackPanel>
                <DockPanel Margin="0,4,0,6">
                    <Label DockPanel.Dock="Left" Content="{DynamicResource str_label_input}" Width="68"/>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource str_btn_browse}" Margin="6,0,0,0"
                            Click="BrowseCsvInput_Click"
                            ToolTip="{DynamicResource str_tt_csv_browse}"/>
                    <TextBox x:Name="TxtCsvInput" ToolTip="{DynamicResource str_tt_csv_input}"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="68,0,0,5">
                    <RadioButton x:Name="RbCsvOverwrite" GroupName="CsvOut"
                                 Content="{DynamicResource str_rb_overwrite}"
                                 IsChecked="True" Margin="0,0,24,0"
                                 Checked="CsvOutOption_Changed"
                                 ToolTip="{DynamicResource str_tt_rb_overwrite_csv}"/>
                    <RadioButton x:Name="RbCsvSeparate" GroupName="CsvOut"
                                 Content="{DynamicResource str_rb_separate}"
                                 Checked="CsvOutOption_Changed"
                                 ToolTip="{DynamicResource str_tt_rb_separate_csv}"/>
                </StackPanel>
                <DockPanel Margin="68,0,0,4">
                    <Button DockPanel.Dock="Right" x:Name="BtnBrowseCsvOutput"
                            Content="{DynamicResource str_btn_browse}" Margin="6,0,0,0" IsEnabled="False"
                            Click="BrowseCsvOutput_Click"
                            ToolTip="{DynamicResource str_tt_csv_output_browse}"/>
                    <TextBox x:Name="TxtCsvOutput" IsEnabled="False" Foreground="Gray"
                             ToolTip="{DynamicResource str_tt_csv_output}"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- ══ Präfix + Start-Button ══ -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="{DynamicResource str_label_prefix}"
                   ToolTip="{DynamicResource str_tt_prefix}"/>
            <TextBox x:Name="TxtPrefix" Grid.Column="1"
                     ToolTip="{DynamicResource str_tt_prefix}"/>
            <Button Grid.Column="3" x:Name="BtnConvert"
                    Content="{DynamicResource str_btn_convert}"
                    Height="36" Padding="20,5" FontSize="13" FontWeight="Bold"
                    Background="#2a9a2a" Foreground="White" BorderBrush="#1e7a1e"
                    Click="BtnConvert_Click"
                    ToolTip="{DynamicResource str_tt_btn_convert}"/>
        </Grid>

        <!-- ══ Protokoll ══ -->
        <GroupBox Grid.Row="4" Header="{DynamicResource str_group_log}">
            <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     Background="#f6f6f6" BorderThickness="0"/>
        </GroupBox>
    </Grid>
</Window>